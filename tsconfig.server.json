{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["bun-types"],
    "outDir": "dist/server",
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src/server/**/*", "src/shared/**/*", "drizzle.config.ts"]
}
