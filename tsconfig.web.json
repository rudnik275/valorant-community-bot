{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "outDir": "dist/web",
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src/web/**/*", "src/shared/**/*"]
}
