    "grammy": "^1.36.0",
    "hono": "^4.7.0",
    "pino": "^9.6.0",
    "vue": "^3.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@vitejs/plugin-vue": "^5.2.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.31.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  }
